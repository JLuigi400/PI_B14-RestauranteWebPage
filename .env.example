# Configuración de la Base de Datos
DB_HOST=localhost
DB_PORT=3307
DB_NAME=restaurantes
DB_USER=root
DB_PASS=

# Configuración del Sitio
SITIO_NOMBRE="Restaurantes Saludables - Cd. Juárez"
SITIO_URL=http://localhost/restaurantes/
SITIO_VERSION=1.0.0

# Configuración de Sesión
SESSION_NAME=restaurantes_session
SESSION_LIFETIME=86400

# Configuración de Subida de Archivos
MAX_FILE_SIZE=10485760
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp

# Configuración de Seguridad
HASH_ALGORITHM=PASSWORD_DEFAULT
SALT_LENGTH=32

# Configuración de Errores
DEBUG_MODE=true
LOG_ERRORS=true
LOG_FILE=logs/error.log

# Configuración de Correo (Opcional)
MAIL_HOST=localhost
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM_EMAIL=noreply@restaurantesjuarez.com
MAIL_FROM_NAME="Restaurantes Saludables - Cd. Juárez"

# Configuración de Paginación
ITEMS_POR_PAGINA=12

# Configuración de Caché
CACHE_ACTIVO=false
CACHE_TIEMPO=3600

# Configuración de Roles
ROL_ADMIN=1
ROL_DUEÑO=2
ROL_COMENSAL=3
