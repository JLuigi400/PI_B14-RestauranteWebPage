_screenshots/

# SaveStates locales (respaldo de código)
SaveStates/

# Archivos SQL locales (solo se usan localmente)
SQL/

# Archivos ZIP (comprimidos varios)
*.zip
*.rar
*.7z
*.tar.gz

# Archivos de caché
.cache/
*.cache

# Certificados SSL (si los hay)
*.pem
