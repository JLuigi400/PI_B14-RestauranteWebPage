!UPLOADS/.gitkeep
IMG/*
!IMG/.gitkeep

# Dependencias y vendor
/vendor/
composer.lock
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# IDE y editores
.vscode/
.idea/
*.sublime-project
*.sublime-workspace
*.code-workspace

# Backup y archivos de base de datos
*.sql.backup
*.db.backup
database_backups/

# XAMPP y configuración local
xampp/
htdocs_backup/

# CARPETAS Y ARCHIVOS LOCALES QUE NO SE SUBEN A GITHUB
