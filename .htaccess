# Configuración básica para pruebas - Sin reglas complejas

# Activar motor de reescritura (básico)
RewriteEngine On

# Permitir acceso a archivos PHP
<Files "*.php">
    Order allow,deny
    Allow from all
</Files>

# Mostrar errores para depuración
php_flag display_errors On
php_value error_reporting E_ALL

# Configuración básica de seguridad
# Sin bloqueos temporales para pruebas
